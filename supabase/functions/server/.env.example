## Supabase Edge Function (server) environment variables
## Required for persistent storage (Postgres via service role)
## Recommended for real deployments: AUTH_MODE=supabase
## Note: in AUTH_MODE=supabase, approving coach registrations creates a Supabase Auth user via service role and triggers a password reset email (requires SMTP configured in Supabase).
AUTH_MODE=supabase
SUPABASE_URL=
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=
ADMIN_SIGNUP_CODE=

## Optional: absolute base URL for QR/receipt links
PUBLIC_APP_BASE_URL=http://localhost:5173

## Optional: auth hardening
## If true, rejects header-only auth and requires Authorization: Bearer <token>
AUTH_REQUIRE_BEARER=false

## Optional: allow privileged signup (admin/staff)
AUTH_ALLOW_PRIVILEGED_SIGNUP=false

## Optional: password policy (applies to backend `/auth/signup` and `/auth/change-password`)
AUTH_PASSWORD_MIN_LENGTH=6

## Optional: rate limiting overrides (max requests per window)
## Examples:
## RATE_LIMIT_AUTH_LOGIN_MAX=10
## RATE_LIMIT_AUTH_LOGIN_WINDOW_SEC=60
## RATE_LIMIT_AUTH_SIGNUP_MAX=5
## RATE_LIMIT_AUTH_SIGNUP_WINDOW_SEC=60
## RATE_LIMIT_BOOKING_CREATE_MAX=30
## RATE_LIMIT_BOOKING_CREATE_WINDOW_SEC=60
## RATE_LIMIT_PAYMENT_CHECKOUT_MAX=20
## RATE_LIMIT_PAYMENT_CHECKOUT_WINDOW_SEC=60
## RATE_LIMIT_PAYMENT_WEBHOOK_MAX=60
## RATE_LIMIT_PAYMENT_WEBHOOK_WINDOW_SEC=60

## Optional: payment provider configuration
## PAYMENT_PROVIDER=mock|gateway
PAYMENT_PROVIDER=mock
PAYMENT_API_KEY=
PAYMENT_CHECKOUT_URL=
PAYMENT_WEBHOOK_SECRET=
PAYMENT_SUCCESS_URL=
PAYMENT_CANCEL_URL=

## Optional: booking payment deadline default (minutes)
BOOKING_PAYMENT_DEADLINE_MINUTES=30
